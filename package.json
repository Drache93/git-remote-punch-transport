{
  "name": "git-remote-punch",
  "version": "0.3.0",
  "description": "Git over holepunch remote helper.",
  "pear": {
    "name": "git-remote-punch",
    "pre": "pear-electron/pre",
    "gui": {
      "width": "1024",
      "height": "768"
    },
    "routes": {
      "remote": "remote.js",
      "tui": "tui.js"
    },
    "stage": {
      "ignore": [
        ".git",
        ".vscode",
        "example",
        "example.js",
        "test"
      ]
    }
  },
  "bin": {
    "git-remote-git+pear": "bin.js",
    "gp": "bin-tui.js"
  },
  "scripts": {
    "test": "brittle test/*.js && brittle-bare gui/all.js",
    "fix": "prettier --write",
    "schema": "node schemas/local.js && node schemas/remote.js",
    "postinstall": "patch-package",
    "dev": "npm run clean && npm run build && ./out/darwin-arm64/git-pear.app/Contents/MacOS/git-pear",
    "build": "bare-build --out out/darwin-arm64 --host darwin-arm64 --name git-pear --runtime bare-native/runtime gui/app.js",
    "build:adapters:css": "tailwindcss -i ./gui/adapters/html/input.css -o ./gui/adapters/html/output.css",
    "build:android": "bare-build --out out/android-arm64 --host android-arm64 --identifier io.pear.git --name GitPear --runtime bare-native/runtime gui/app.js",
    "clean": "rm -rf out"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "bare-build": "^0.4.5",
    "brittle": "^3.18.0",
    "hyperdht": "^6.21.0",
    "prettier-config-holepunch": "^2.0.0",
    "standard": "^17.1.2",
    "tailwindcss": "^4.2.1",
    "test-tmp": "^1.4.0"
  },
  "imports": {
    "#target": {
      "default": "./gui/target/default.js"
    },
    "buffer": {
      "bare": "bare-buffer",
      "default": "buffer"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    },
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "net": {
      "bare": "bare-net",
      "default": "net"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "readline": {
      "bare": "bare-readline",
      "default": "readline"
    },
    "tty": {
      "bare": "bare-tty",
      "default": "tty"
    }
  },
  "dependencies": {
    "b4a": "^1.6.7",
    "bare-buffer": "^3.3.0",
    "bare-console": "^6.1.0",
    "bare-fs": "^4.1.6",
    "bare-http1": "^4.3.0",
    "bare-native": "^0.1.2",
    "bare-net": "^2.1.1",
    "bare-os": "^3.6.1",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.1",
    "bare-readline": "^1.0.9",
    "bare-spinner": "^1.0.2",
    "bare-storage": "^1.1.0",
    "bare-string-decoder": "^1.0.0",
    "bare-subprocess": "^5.1.0",
    "bare-tty": "^5.0.2",
    "bare-ws": "^2.1.0",
    "blind-peering": "^1.10.1",
    "cellery": "^1.4.3",
    "cellery-html": "^1.1.7",
    "compact-encoding": "^2.16.1",
    "compact-encoding-struct": "^1.3.0",
    "coremachine": "^1.1.0",
    "corestore": "^7.4.5",
    "graceful-goodbye": "^1.3.3",
    "hyperbee2": "^2.7.1",
    "hypercore": "^11.16.1",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdb": "^6.3.0",
    "hyperschema": "^1.20.1",
    "hyperswarm": "^4.14.0",
    "keet-identity-key": "^3.1.0",
    "paparam": "^1.8.6",
    "pear-bridge": "^1.2.4",
    "pear-electron": "^1.7.25",
    "pear-link": "^4.2.1",
    "pear-pipe": "^1.0.1",
    "pear-run": "^1.0.0",
    "protomux-wakeup": "^2.6.1",
    "ready-resource": "^1.1.2",
    "rebuild-git": "^1.0.0",
    "sodium-native": "^5.0.9",
    "streamx": "^2.23.0",
    "z32": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/git-remote-punch-transport.git"
  },
  "bugs": {
    "url": "https://github.com/holepunchto/git-remote-punch-transport/issues"
  },
  "homepage": "https://github.com/holepunchto/git-remote-punch-transport#readme"
}
