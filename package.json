{
  "name": "git-remote-punch",
  "version": "0.2.0",
  "description": "Git over holepunch remote helper.",
  "pear": {
    "name": "git-remote-punch",
    "pre": "pear-electron/pre",
    "gui": {
      "width": "1024",
      "height": "768"
    },
    "routes": {
      "remote": "remote.js",
      "tui": "tui.js"
    },
    "stage": {
      "ignore": [
        ".git",
        ".vscode",
        "example",
        "example.js",
        "test"
      ]
    }
  },
  "bin": {
    "git-remote-git+pear": "bin.js"
  },
  "scripts": {
    "test": "brittle test/*.js",
    "fix": "prettier --write",
    "schema": "node schemas/local.js && node schemas/remote.js",
    "postinstall": "patch-package"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "brittle": "^3.18.0",
    "hyperdht": "^6.21.0",
    "patch-package": "^8.0.1",
    "prettier-config-holepunch": "^2.0.0",
    "standard": "^17.1.2",
    "test-tmp": "^1.4.0"
  },
  "imports": {
    "buffer": {
      "bare": "bare-buffer",
      "default": "buffer"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    },
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "net": {
      "bare": "bare-net",
      "default": "net"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "readline": {
      "bare": "bare-readline",
      "default": "readline"
    },
    "tty": {
      "bare": "bare-tty",
      "default": "tty"
    }
  },
  "dependencies": {
    "@holepunchto/bare-translations": "^0.2.1",
    "b4a": "^1.6.7",
    "bare-buffer": "^3.3.0",
    "bare-fs": "^4.1.6",
    "bare-net": "^2.1.1",
    "bare-os": "^3.6.1",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.1",
    "bare-readline": "^1.0.9",
    "bare-spinner": "^1.0.2",
    "bare-string-decoder": "^1.0.0",
    "bare-subprocess": "^5.1.0",
    "bare-tty": "^5.0.2",
    "blind-peering": "^1.10.1",
    "compact-encoding": "^2.16.1",
    "compact-encoding-net": "^1.2.0",
    "compact-encoding-struct": "^1.3.0",
    "corestore": "^7.4.5",
    "cross-worker": "^1.2.1",
    "graceful-goodbye": "^1.3.3",
    "hyperbee": "^2.26.4",
    "hyperbee2": "^1.1.1",
    "hyperblobs": "^2.8.0",
    "hypercore": "^11.16.1",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdb": "^4.16.1",
    "hyperschema": "^1.14.0",
    "hyperswarm": "^4.14.0",
    "isomorphic-git": "^1.33.0",
    "keet-identity-key": "^3.1.0",
    "ora": "^8.2.0",
    "paparam": "^1.8.6",
    "pear-bridge": "^1.2.4",
    "pear-electron": "^1.7.25",
    "pear-inspect": "^1.2.5",
    "pear-link": "^4.2.1",
    "pear-pipe": "^1.0.1",
    "pear-run": "^1.0.0",
    "protomux-wakeup": "^2.6.1",
    "ready-resource": "^1.1.2",
    "rocksdb-native": "^3.7.5",
    "sodium-native": "^5.0.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/git-remote-punch-transport.git"
  },
  "bugs": {
    "url": "https://github.com/holepunchto/git-remote-punch-transport/issues"
  },
  "homepage": "https://github.com/holepunchto/git-remote-punch-transport#readme"
}
